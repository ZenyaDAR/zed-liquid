{
  "if": {
    "prefix": "if",
    "body": ["{% if ${1:condition} %}", "\t$0", "{% endif %}"],
    "description": "if statement"
  },
  "if/else": {
    "prefix": "ife",
    "body": [
      "{% if ${1:condition} %}",
      "\t$2",
      "{% else %}",
      "\t$0",
      "{% endif %}"
    ],
    "description": "if/else statement"
  },
  "if/elsif/else": {
    "prefix": "ifee",
    "body": [
      "{% if ${1:condition} %}",
      "\t$2",
      "{% elsif ${3:condition} %}",
      "\t$4",
      "{% else %}",
      "\t$0",
      "{% endif %}"
    ],
    "description": "if/elsif/else statement"
  },
  "unless": {
    "prefix": "unless",
    "body": ["{% unless ${1:condition} %}", "\t$0", "{% endunless %}"],
    "description": "unless statement"
  },
  "unless/else": {
    "prefix": "unle",
    "body": [
      "{% unless ${1:condition} %}",
      "\t$2",
      "{% else %}",
      "\t$0",
      "{% endunless %}"
    ],
    "description": "unless/else statement"
  },
  "for": {
    "prefix": "for",
    "body": ["{% for ${1:item} in ${2:collection} %}", "\t$0", "{% endfor %}"],
    "description": "for loop"
  },
  "for with limit/offset": {
    "prefix": "forl",
    "body": [
      "{% for ${1:item} in ${2:collection} limit: ${3:5} offset: ${4:0} %}",
      "\t$0",
      "{% endfor %}"
    ],
    "description": "for loop with limit and offset"
  },
  "tablerow": {
    "prefix": "tablerow",
    "body": [
      "{% tablerow ${1:item} in ${2:collection} %}",
      "\t$0",
      "{% endtablerow %}"
    ],
    "description": "tablerow loop (renders an HTML table row per item)"
  },
  "cycle": {
    "prefix": "cycle",
    "body": ["{% cycle '${1:one}', '${2:two}', '${3:three}' %}"],
    "description": "cycle — rotates through values on each iteration"
  },
  "assign": {
    "prefix": "assign",
    "body": ["{% assign ${1:variable} = ${2:value} %}"],
    "description": "assign variable"
  },
  "capture": {
    "prefix": "capture",
    "body": ["{% capture ${1:variable} %}", "\t$0", "{% endcapture %}"],
    "description": "capture block"
  },
  "case/when": {
    "prefix": "case",
    "body": [
      "{% case ${1:variable} %}",
      "  {% when ${2:value} %}",
      "\t$3",
      "  {% when ${4:value} %}",
      "\t$0",
      "{% endcase %}"
    ],
    "description": "case/when statement"
  },
  "include": {
    "prefix": "include",
    "body": ["{% include '${1:snippet}'${2:, ${3:param}: ${4:value}} %}"],
    "description": "include snippet (deprecated — prefer render)"
  },
  "render": {
    "prefix": "render",
    "body": ["{% render '${1:snippet}'${2:, ${3:param}: ${4:value}} %}"],
    "description": "render snippet"
  },
  "render with": {
    "prefix": "renderw",
    "body": [
      "{% render '${1:snippet}', ${2:param}: ${3:value} %}"
    ],
    "description": "render snippet with parameter"
  },
  "section": {
    "prefix": "section",
    "body": ["{% section '${1:name}' %}"],
    "description": "section tag"
  },
  "sections": {
    "prefix": "sections",
    "body": ["{% sections '${1:name}' %}"],
    "description": "sections tag"
  },
  "paginate": {
    "prefix": "paginate",
    "body": [
      "{% paginate ${1:collection} by ${2:12} %}",
      "\t$0",
      "{% endpaginate %}"
    ],
    "description": "paginate block"
  },
  "comment": {
    "prefix": "comment",
    "body": ["{% comment %}", "\t$0", "{% endcomment %}"],
    "description": "comment block"
  },
  "raw": {
    "prefix": "raw",
    "body": ["{% raw %}", "\t$0", "{% endraw %}"],
    "description": "raw block (no Liquid processing)"
  },
  "schema": {
    "prefix": "schema",
    "body": [
      "{% schema %}",
      "{",
      "\t\"name\": \"${1:Section name}\",",
      "\t\"settings\": [",
      "\t\t$0",
      "\t],",
      "\t\"presets\": [",
      "\t\t{ \"name\": \"${2:Default}\" }",
      "\t]",
      "}",
      "{% endschema %}"
    ],
    "description": "schema block"
  },
  "javascript": {
    "prefix": "javascript",
    "body": ["{% javascript %}", "\t$0", "{% endjavascript %}"],
    "description": "javascript block"
  },
  "stylesheet": {
    "prefix": "stylesheet",
    "body": ["{% stylesheet %}", "\t$0", "{% endstylesheet %}"],
    "description": "stylesheet block"
  },
  "style": {
    "prefix": "style",
    "body": ["{% style %}", "\t$0", "{% endstyle %}"],
    "description": "style block"
  },
  "echo": {
    "prefix": "echo",
    "body": ["{% echo ${1:variable} %}"],
    "description": "echo tag"
  },
  "liquid tag": {
    "prefix": "liquid",
    "body": [
      "{% liquid",
      "\t${1:assign var = 'value'}",
      "%}"
    ],
    "description": "liquid tag (multiple statements)"
  },
  "increment": {
    "prefix": "increment",
    "body": ["{% increment ${1:variable} %}"],
    "description": "increment variable"
  },
  "decrement": {
    "prefix": "decrement",
    "body": ["{% decrement ${1:variable} %}"],
    "description": "decrement variable"
  },
  "layout": {
    "prefix": "layout",
    "body": ["{% layout ${1:'theme'} %}"],
    "description": "layout tag"
  },
  "form": {
    "prefix": "form",
    "body": ["{% form '${1:type}'${2:, ${3:object}} %}", "\t$0", "{% endform %}"],
    "description": "form tag"
  },
  "output variable": {
    "prefix": "{{",
    "body": ["{{ ${1:variable} }}"],
    "description": "output Liquid variable"
  },
  "output with filter": {
    "prefix": "{{f",
    "body": ["{{ ${1:variable} | ${2:filter} }}"],
    "description": "output variable with filter"
  },
  "t filter": {
    "prefix": "t",
    "body": ["{{ '${1:key}' | t }}"],
    "description": "translation filter"
  },
  "date filter": {
    "prefix": "{{date",
    "body": ["{{ ${1:variable} | date: '${2:%B %d, %Y}' }}"],
    "description": "output variable formatted as date"
  },
  "money filter": {
    "prefix": "{{money",
    "body": ["{{ ${1:variable} | money }}"],
    "description": "output price formatted as money"
  },
  "money with currency filter": {
    "prefix": "{{moneyc",
    "body": ["{{ ${1:variable} | money_with_currency }}"],
    "description": "output price formatted as money with currency"
  },
  "default filter": {
    "prefix": "{{def",
    "body": ["{{ ${1:variable} | default: '${2:fallback}' }}"],
    "description": "output variable with fallback default value"
  },
  "truncate filter": {
    "prefix": "{{trunc",
    "body": ["{{ ${1:variable} | truncate: ${2:100} }}"],
    "description": "output variable truncated to N characters"
  },
  "assign where": {
    "prefix": "assignw",
    "body": ["{% assign ${1:result} = ${2:collection} | where: '${3:property}', '${4:value}' %}"],
    "description": "assign filtered array using where filter"
  },
  "assign map": {
    "prefix": "assignm",
    "body": ["{% assign ${1:result} = ${2:collection} | map: '${3:property}' %}"],
    "description": "assign mapped array of a single property"
  },
  "asset url": {
    "prefix": "asset",
    "body": ["{{ '${1:file.css}' | asset_url }}"],
    "description": "output asset URL"
  },
  "stylesheet link": {
    "prefix": "assetlink",
    "body": ["{{ '${1:style.css}' | asset_url | stylesheet_tag }}"],
    "description": "output asset as <link> stylesheet tag"
  },
  "image_tag": {
    "prefix": "imgtag",
    "body": ["{{ ${1:image} | image_url: width: ${2:800} | image_tag: alt: '${3:alt}' }}"],
    "description": "responsive image with image_url + image_tag"
  },
  "content_for_header": {
    "prefix": "cfh",
    "body": ["{{ content_for_header }}"],
    "description": "Shopify header hook (required in <head>)"
  },
  "content_for_layout": {
    "prefix": "cfl",
    "body": ["{{ content_for_layout }}"],
    "description": "Shopify main content hook (required in layout)"
  },
  "content_for_index": {
    "prefix": "cfi",
    "body": ["{{ content_for_index }}"],
    "description": "Shopify home page sections hook"
  },
  "script_tag filter": {
    "prefix": "scripttag",
    "body": ["{{ '${1:app.js}' | asset_url | script_tag }}"],
    "description": "output asset as <script> tag"
  },
  "escape filter": {
    "prefix": "{{esc",
    "body": ["{{ ${1:variable} | escape }}"],
    "description": "HTML-escape output"
  },
  "strip_html filter": {
    "prefix": "{{strip",
    "body": ["{{ ${1:variable} | strip_html }}"],
    "description": "strip HTML tags"
  },
  "handle filter": {
    "prefix": "{{handle",
    "body": ["{{ ${1:variable} | handle }}"],
    "description": "URL-safe handle"
  },
  "size filter": {
    "prefix": "{{size",
    "body": ["{{ ${1:variable} | size }}"],
    "description": "count of array/string"
  },
  "assign sort": {
    "prefix": "assignsort",
    "body": ["{% assign ${1:result} = ${2:array} | sort: '${3:property}' %}"],
    "description": "sorted array"
  },
  "assign first": {
    "prefix": "assignfirst",
    "body": ["{% assign ${1:result} = ${2:array} | where: '${3:prop}', '${4:val}' | first %}"],
    "description": "first matching item"
  },
  "full section template": {
    "prefix": "section-template",
    "body": [
      "<div class=\"${1:section-name}\">",
      "\t$0",
      "</div>",
      "",
      "{% schema %}",
      "{",
      "\t\"name\": \"${2:Section Name}\",",
      "\t\"tag\": \"section\",",
      "\t\"class\": \"${1:section-name}\",",
      "\t\"settings\": [],",
      "\t\"presets\": [{ \"name\": \"${2:Section Name}\" }]",
      "}",
      "{% endschema %}",
      "",
      "{% stylesheet %}",
      "{% endstylesheet %}",
      "",
      "{% javascript %}",
      "{% endjavascript %}"
    ],
    "description": "full Shopify section boilerplate"
  }
}
